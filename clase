<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Python — EPN · Desde Cero</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,700;1,400&family=Sora:wght@300;400;600;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --dark:#0D1117;--navy:#161B22;--card:#21262D;--card2:#2D333B;
  --blue:#1F6FEB;--yellow:#F0DB4F;--green:#3FB950;
  --orange:#F78166;--purple:#BC8CFF;--cyan:#58A6FF;
  --white:#F0F6FC;--muted:#8B949E;--red:#F85149;
  --mono:'JetBrains Mono',monospace;--sans:'Sora',sans-serif;
}
html,body{width:100%;height:100%;overflow:hidden;background:var(--dark);font-family:var(--sans)}
button{cursor:pointer;font-family:var(--sans)}

/* ── DECK ── */
#deck{width:100vw;height:100vh;position:relative}
.slide{
  position:absolute;inset:0;display:flex;flex-direction:column;
  background:var(--dark);opacity:0;pointer-events:none;
  transition:opacity .4s ease,transform .4s ease;
  transform:translateX(50px);overflow:hidden
}
.slide.active{opacity:1;pointer-events:all;transform:translateX(0)}
.slide.out{opacity:0;transform:translateX(-50px)}

/* ── PROGRESS ── */
#progress-wrap{position:fixed;top:0;left:0;right:0;height:3px;background:rgba(255,255,255,.06);z-index:200}
#progress-bar{height:100%;background:linear-gradient(90deg,var(--blue),var(--purple),var(--yellow));transition:width .4s ease;border-radius:0 2px 2px 0}

/* ── NAV ── */
#nav{
  position:fixed;bottom:20px;left:50%;transform:translateX(-50%);
  display:flex;align-items:center;gap:10px;
  background:rgba(22,27,34,.95);backdrop-filter:blur(16px);
  border:1px solid rgba(255,255,255,.1);border-radius:40px;
  padding:8px 20px;z-index:100;box-shadow:0 8px 32px rgba(0,0,0,.4)
}
.nbtn{background:none;border:none;color:var(--muted);font-size:16px;
  padding:4px 10px;border-radius:8px;transition:all .15s}
.nbtn:hover{color:var(--white);background:rgba(255,255,255,.08)}
#ctr{font-family:var(--mono);font-size:12px;color:var(--muted);min-width:48px;text-align:center}
#slide-dots{display:flex;gap:4px;align-items:center}
.sdot{width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,.2);transition:all .3s}
.sdot.on{background:var(--cyan);width:14px;border-radius:3px}

/* ── HEADER ── */
.hdr{display:flex;align-items:center;height:52px;background:var(--navy);
  border-bottom:1px solid rgba(255,255,255,.05);flex-shrink:0}
.hdr-bar{width:4px;height:100%;flex-shrink:0;border-radius:0 3px 3px 0}
.hdr-title{font-size:18px;font-weight:600;color:var(--white);padding:0 20px;flex:1}
.hdr-tag{font-family:var(--mono);font-size:10px;padding:3px 10px;border-radius:20px;
  border:1px solid currentColor;margin-right:14px;opacity:.7}

/* ── BODY ── */
.sbody{flex:1;display:flex;padding:20px 32px 68px;gap:18px;overflow:hidden}
.col{display:flex;flex-direction:column;gap:14px}
.f1{flex:1}.f2{flex:2}

/* ── CARDS ── */
.card{background:var(--card);border-radius:10px;padding:18px;
  border:1px solid rgba(255,255,255,.06);position:relative;overflow:hidden}
.card-top{position:absolute;top:0;left:0;right:0;height:3px}

/* ── CODE ── */
.cblock{background:#0A0E14;border-radius:8px;padding:12px 16px;
  font-family:var(--mono);font-size:13px;line-height:1.75;
  border:1px solid rgba(255,255,255,.08)}
.cdots{display:flex;gap:5px;margin-bottom:8px}
.cd{width:9px;height:9px;border-radius:50%}
.kw{color:var(--yellow);font-weight:700}
.fn{color:#DCDCAA}
.st{color:#CE9178}
.nm{color:#B5CEA8}
.vr{color:var(--cyan)}
.cm{color:var(--muted);font-style:italic}
.op{color:var(--orange)}
.out{color:var(--green)}
.cls{color:var(--purple)}

/* ── OUTPUT ── */
.outblock{background:#0A0E14;border-radius:6px;border-left:3px solid var(--green);
  padding:8px 14px;font-family:var(--mono);font-size:13px;line-height:1.7}

/* ── INTERACTIVE CONSOLE ── */
.console{background:#0A0E14;border-radius:10px;border:1px solid rgba(88,166,255,.25);overflow:hidden;display:flex;flex-direction:column}
.console-bar{background:#161B22;padding:8px 14px;display:flex;align-items:center;gap:8px;border-bottom:1px solid rgba(255,255,255,.06)}
.console-bar span{font-family:var(--mono);font-size:11px;color:var(--muted)}
.console-output{flex:1;padding:10px 14px;font-family:var(--mono);font-size:13px;line-height:1.8;min-height:80px;overflow-y:auto}
.console-input-row{display:flex;align-items:center;border-top:1px solid rgba(255,255,255,.06);padding:6px 12px;gap:8px}
.console-prompt{color:var(--green);font-family:var(--mono);font-size:13px;flex-shrink:0}
.console-input{flex:1;background:none;border:none;outline:none;color:var(--white);
  font-family:var(--mono);font-size:13px;caret-color:var(--green)}
.run-btn{background:var(--green);color:#0D1117;border:none;border-radius:5px;
  padding:4px 12px;font-size:12px;font-weight:700;transition:all .15s}
.run-btn:hover{filter:brightness(1.1);transform:scale(1.03)}
.out-line{animation:fadeIn .2s ease}
.err-line{color:var(--red)}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}

/* ── MEMORY MODEL ── */
.mem-box{background:#0A0E14;border:2px solid var(--cyan);border-radius:8px;
  padding:10px 16px;text-align:center;min-width:90px;transition:all .4s;position:relative}
.mem-name{font-family:var(--mono);font-size:11px;color:var(--muted);margin-bottom:4px}
.mem-val{font-family:var(--mono);font-size:20px;font-weight:700}
.mem-type{font-family:var(--mono);font-size:10px;margin-top:3px;opacity:.7}
.mem-arrow{color:var(--purple);font-size:18px;padding:0 4px}

/* ── DRAG & DROP ── */
.drag-item{background:var(--card2);border:1px solid rgba(255,255,255,.1);
  border-radius:6px;padding:8px 14px;cursor:grab;font-family:var(--mono);
  font-size:13px;user-select:none;transition:all .2s}
.drag-item:hover{border-color:var(--cyan);transform:scale(1.03)}
.drag-item.dragging{opacity:.4;cursor:grabbing}
.drop-zone{border:2px dashed rgba(255,255,255,.15);border-radius:8px;
  min-height:44px;padding:8px;display:flex;align-items:center;justify-content:center;
  transition:all .2s;font-family:var(--sans);font-size:13px;color:var(--muted)}
.drop-zone.over{border-color:var(--cyan);background:rgba(88,166,255,.08)}
.drop-zone.correct{border-color:var(--green);background:rgba(63,185,80,.12)}
.drop-zone.wrong{border-color:var(--red);background:rgba(248,81,73,.12)}

/* ── QUIZ ── */
.qbtn{background:var(--card2);border:1px solid rgba(255,255,255,.1);
  border-radius:7px;padding:10px 16px;text-align:left;color:var(--white);
  font-size:13px;display:flex;align-items:center;gap:10px;transition:all .2s;width:100%}
.qbtn:hover:not(:disabled){border-color:var(--cyan);background:rgba(88,166,255,.08);transform:translateX(3px)}
.qbtn.ok{border-color:var(--green);background:rgba(63,185,80,.12);color:var(--green)}
.qbtn.no{border-color:var(--red);background:rgba(248,81,73,.1);color:var(--red)}
.qbtn:disabled{cursor:default}

/* ── FILL IN THE BLANK ── */
.blank{display:inline-block;min-width:80px;border-bottom:2px solid var(--cyan);
  padding:0 4px;margin:0 4px;font-family:var(--mono);font-size:13px;color:var(--cyan);
  background:rgba(88,166,255,.06);border-radius:3px;outline:none;
  text-align:center;transition:all .2s}
.blank:focus{border-color:var(--yellow);background:rgba(240,219,79,.06)}
.blank.ok{border-color:var(--green);color:var(--green);background:rgba(63,185,80,.1)}
.blank.no{border-color:var(--red);color:var(--red);background:rgba(248,81,73,.1)}

/* ── TYPE DETECTOR ── */
.type-detector input{background:#0A0E14;border:1px solid rgba(255,255,255,.15);
  border-radius:7px;padding:10px 14px;color:var(--white);font-family:var(--mono);
  font-size:14px;outline:none;width:100%;transition:border-color .2s}
.type-detector input:focus{border-color:var(--cyan)}
.type-badge{display:inline-block;padding:6px 18px;border-radius:20px;
  font-family:var(--mono);font-weight:700;font-size:15px;border:2px solid currentColor;
  transition:all .3s}

/* ── TEMP CONVERTER ── */
.conv-slider{-webkit-appearance:none;appearance:none;width:100%;height:6px;
  border-radius:3px;background:linear-gradient(90deg,var(--blue),var(--orange));outline:none}
.conv-slider::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;
  width:20px;height:20px;border-radius:50%;background:var(--white);cursor:pointer;box-shadow:0 0 8px rgba(0,0,0,.4)}

/* ── SCORE ── */
#score-wrap{position:fixed;top:12px;right:18px;z-index:100;
  background:rgba(22,27,34,.9);backdrop-filter:blur(8px);
  border:1px solid rgba(255,255,255,.08);border-radius:20px;
  padding:5px 14px;font-family:var(--mono);font-size:12px;color:var(--muted);
  display:flex;align-items:center;gap:6px}
#score-pts{color:var(--yellow);font-weight:700;transition:all .3s}

/* ── CONFETTI ── */
.confetti-piece{position:fixed;width:8px;height:8px;border-radius:2px;
  pointer-events:none;animation:confettiFall 1.2s ease forwards;z-index:9999}
@keyframes confettiFall{
  0%{transform:translateY(-10px) rotate(0deg);opacity:1}
  100%{transform:translateY(100vh) rotate(720deg);opacity:0}
}

/* ── COVER ── */
#cover{justify-content:center;align-items:center}
.blob{position:absolute;border-radius:50%;filter:blur(90px);pointer-events:none}
.cover-title{font-size:clamp(50px,8vw,100px);font-weight:800;color:var(--white);
  letter-spacing:-2px;animation:up .6s ease both}
.cover-line{width:260px;height:3px;background:linear-gradient(90deg,var(--blue),var(--yellow));
  margin:16px auto;animation:growX .5s .3s ease both;transform-origin:left;border-radius:2px}
.cover-sub{font-size:16px;color:var(--yellow);text-align:center;animation:up .5s .4s ease both;opacity:0;animation-fill-mode:both}
.cover-desc{font-size:13px;color:var(--muted);font-style:italic;text-align:center;margin-top:6px;animation:up .5s .55s ease both;opacity:0;animation-fill-mode:both}
.cover-epn{font-family:var(--mono);font-size:12px;color:var(--blue);margin-top:4px;text-align:center;animation:up .5s .6s ease both;opacity:0;animation-fill-mode:both}
.cover-chips{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-top:22px;animation:up .5s .7s ease both;opacity:0;animation-fill-mode:both}
.chip{display:inline-flex;align-items:center;gap:5px;padding:5px 14px;border-radius:20px;
  font-family:var(--mono);font-size:11px;font-weight:700;border:1px solid currentColor;background:rgba(0,0,0,.3)}
@keyframes up{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:none}}
@keyframes growX{from{transform:scaleX(0)}to{transform:scaleX(1)}}

/* ── STEP CARDS ── */
.step{display:flex;align-items:center;gap:14px;background:var(--card);border-radius:9px;
  padding:14px 18px;border:1px solid rgba(255,255,255,.06);border-left:3px solid currentColor;
  transition:transform .2s}
.step:hover{transform:translateX(3px)}
.step-n{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;
  justify-content:center;font-family:var(--mono);font-size:13px;font-weight:700;
  background:currentColor;flex-shrink:0}
.step-n span{color:#0D1117}

/* ── TYPE GRID ── */
.tgrid{display:grid;grid-template-columns:1fr 1fr;gap:14px;flex:1}
.tcard{background:var(--card);border-radius:10px;overflow:hidden;border:1px solid rgba(255,255,255,.07);transition:transform .2s}
.tcard:hover{transform:translateY(-2px)}
.thead{padding:11px 16px;display:flex;align-items:center;gap:9px;border-bottom:1px solid rgba(255,255,255,.05)}
.tbody{padding:12px 16px}
.tname{font-family:var(--mono);font-weight:700;font-size:17px}
.tfull{color:var(--muted);font-size:12px;margin-bottom:8px}

/* ── OP GRID ── */
.ogrid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.ocard{background:var(--card);border-radius:9px;padding:14px;text-align:center;
  border:1px solid rgba(255,255,255,.07);transition:transform .2s;cursor:default}
.ocard:hover{transform:translateY(-3px)}
.osym{font-family:var(--mono);font-size:24px;font-weight:700;margin-bottom:2px}
.oname{font-size:11px;color:var(--muted);margin-bottom:8px}

/* ── VAR NAMER ── */
.name-input{background:#0A0E14;border:2px solid rgba(255,255,255,.1);border-radius:8px;
  padding:10px 14px;color:var(--white);font-family:var(--mono);font-size:15px;
  outline:none;width:100%;transition:border-color .2s}
.name-input:focus{border-color:var(--cyan)}
.rule-item{display:flex;align-items:center;gap:10px;padding:7px 12px;border-radius:6px;
  background:var(--card2);font-size:12px;border:1px solid transparent;transition:all .3s}
.rule-icon{font-size:14px;min-width:20px}

/* ── SWAPPER ── */
.mbox{background:#0A0E14;border:2px solid var(--cyan);border-radius:8px;
  padding:12px 20px;text-align:center;min-width:80px;transition:all .5s}
.mbox .mn{font-family:var(--mono);font-size:11px;color:var(--muted);margin-bottom:4px}
.mbox .mv{font-family:var(--mono);font-size:22px;font-weight:700;color:var(--cyan)}

/* ── CLOSING ── */
#cslide{justify-content:center;align-items:center}
.cg{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin:18px 36px;width:100%;max-width:860px}
.cc{background:var(--card);border-radius:10px;overflow:hidden;border-top:3px solid currentColor;
  padding:16px;text-align:center;transition:transform .2s}
.cc:hover{transform:translateY(-3px)}
.ce{font-size:24px;margin-bottom:5px}
.cl{font-size:12px;font-weight:600}

/* ── UTILS ── */
.label{font-size:11px;color:var(--muted);margin-bottom:6px;font-family:var(--mono)}
.body-t{font-size:13px;color:var(--muted);line-height:1.6}
.hl{color:var(--white);font-weight:600}
.sep{height:1px;background:rgba(255,255,255,.06);margin:4px 0}
.info-bar{border-radius:7px;padding:10px 14px;font-size:12px;color:var(--muted);
  background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07)}
.badge{display:inline-block;padding:2px 10px;border-radius:10px;
  font-family:var(--mono);font-size:10px;font-weight:700;border:1px solid currentColor}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1);border-radius:2px}
</style>
</head>
<body>

<div id="progress-wrap"><div id="progress-bar"></div></div>
<div id="score-wrap">⭐ <span id="score-pts">0</span> pts</div>

<div id="deck">

<!-- ═══════════════════ S1 PORTADA ═══════════════════ -->
<div class="slide active" id="cover">
  <div class="blob" style="width:450px;height:450px;top:-120px;left:-120px;background:rgba(31,111,235,.2)"></div>
  <div class="blob" style="width:380px;height:380px;bottom:-80px;right:-60px;background:rgba(188,140,255,.14)"></div>
  <div class="blob" style="width:200px;height:200px;top:80px;right:100px;background:rgba(240,219,79,.1)"></div>
  <div class="cover-title">🐍 Python</div>
  <div class="cover-line"></div>
  <div class="cover-sub">Variables · Tipos · Operaciones · Ejercicios Interactivos</div>
  <div class="cover-desc">Tu primer acercamiento a la programación</div>
  <div class="cover-epn">🏛 Escuela Politécnica Nacional — EPN</div>
  <div class="cover-chips">
    <span class="chip" style="color:var(--green)">🌍 Hola Mundo</span>
    <span class="chip" style="color:var(--cyan)">📦 Variables</span>
    <span class="chip" style="color:var(--orange)">🔢 Tipos</span>
    <span class="chip" style="color:var(--purple)">⚙️ Operaciones</span>
    <span class="chip" style="color:var(--yellow)">🧩 Ejercicios</span>
    <span class="chip" style="color:var(--red)">🏆 Quiz</span>
  </div>
</div>

<!-- ═══════════════════ S2 ¿QUÉ ES PROGRAMAR? ═══════════════════ -->
<div class="slide">
  <div class="hdr"><div class="hdr-bar" style="background:var(--green)"></div><span class="hdr-title">¿Qué es Programar?</span><span class="hdr-tag" style="color:var(--green)">INTRO</span></div>
  <div class="sbody">
    <div class="col f1" style="justify-content:center;gap:12px">
      <div class="card" style="text-align:center;border-color:rgba(63,185,80,.2)">
        <div style="font-size:58px;margin-bottom:10px">👨‍🍳</div>
        <div style="font-weight:600;color:var(--yellow);margin-bottom:8px">Tú eres el chef</div>
        <p class="body-t">Programar es dar <span class="hl">instrucciones exactas</span><br>a una computadora, paso a paso.</p>
      </div>
      <div class="cblock">
        <span class="fn">print</span>(<span class="st">"¡Hola, EPN!"</span>) <span class="cm"># ← tu primera instrucción</span>
      </div>
      <div class="outblock"><span style="color:var(--muted);margin-right:8px">$</span><span style="color:var(--green);font-weight:700">¡Hola, EPN!</span></div>
    </div>
    <div class="col f2" style="justify-content:center;gap:11px">
      <div class="step" style="color:var(--blue)"><div class="step-n"><span>1</span></div><div><div style="font-weight:600;color:var(--white);font-size:14px">Escribes código</div><div class="body-t" style="font-size:12px">Instrucciones en lenguaje Python</div></div></div>
      <div class="step" style="color:var(--yellow)"><div class="step-n"><span>2</span></div><div><div style="font-weight:600;color:var(--white);font-size:14px">Python lo interpreta</div><div class="body-t" style="font-size:12px">Traduce a instrucciones de máquina</div></div></div>
      <div class="step" style="color:var(--orange)"><div class="step-n"><span>3</span></div><div><div style="font-weight:600;color:var(--white);font-size:14px">La CPU lo ejecuta</div><div class="body-t" style="font-size:12px">Procesa millones de operaciones/segundo</div></div></div>
      <div class="step" style="color:var(--green)"><div class="step-n"><span>4</span></div><div><div style="font-weight:600;color:var(--white);font-size:14px">Ves el resultado</div><div class="body-t" style="font-size:12px">¡La magia aparece en pantalla! ✨</div></div></div>
      <div class="info-bar">🏆 Python #1 en popularidad — usado en IA, ciencia, web y automatización</div>
    </div>
  </div>
</div>

<!-- ═══════════════════ S3 HISTORIA HOLA MUNDO ═══════════════════ -->
<div class="slide">
  <div class="hdr"><div class="hdr-bar" style="background:var(--yellow)"></div><span class="hdr-title">La Tradición del «Hola Mundo»</span><span class="hdr-tag" style="color:var(--yellow)">HISTORIA</span></div>
  <div class="sbody" style="flex-direction:column;gap:16px">
    <div style="display:flex;gap:16px">
      <div class="card" style="flex:1;border-top:3px solid var(--orange);text-align:center">
        <div style="font-size:28px;margin-bottom:6px">📖</div>
        <div style="font-family:var(--mono);font-weight:700;color:var(--orange);font-size:18px">1972</div>
        <p class="body-t" style="font-size:12px;margin-top:6px">Brian Kernighan usa<br><em style="color:var(--white)">"hello, world"</em><br>en un tutorial de C</p>
      </div>
      <div class="card" style="flex:1;border-top:3px solid var(--blue);text-align:center">
        <div style="font-size:28px;margin-bottom:6px">📚</div>
        <div style="font-family:var(--mono);font-weight:700;color:var(--blue);font-size:18px">1978</div>
        <p class="body-t" style="font-size:12px;margin-top:6px">Aparece en el libro<br><em style="color:var(--white)">The C Programming<br>Language</em></p>
      </div>
      <div class="card" style="flex:1;border-top:3px solid var(--purple);text-align:center">
        <div style="font-size:28px;margin-bottom:6px">🐍</div>
        <div style="font-family:var(--mono);font-weight:700;color:var(--purple);font-size:18px">1991</div>
        <p class="body-t" style="font-size:12px;margin-top:6px">Python nace con<br><em style="color:var(--white)">Guido van Rossum</em><br>en Países Bajos</p>
      </div>
      <div class="card" style="flex:1;border-top:3px solid var(--green);text-align:center">
