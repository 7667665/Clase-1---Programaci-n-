  const keys=Object.keys(env);
  if(!keys.length){d.innerHTML='<div class="cm" style="font-size:12px">La memoria aparecerá aquí cuando ejecutes código</div>';return;}
  const typeColors={int:'var(--green)',float:'var(--orange)',str:'var(--purple)',bool:'var(--cyan)',NoneType:'var(--muted)'};
  d.innerHTML=keys.map(k=>{
    const v=env[k];const t=getType(v);const c=typeColors[t]||'var(--white)';
    const disp=t==='str'?'"'+v+'"':String(v);
    return `<div class="mem-box" style="border-color:${c}"><div class="mem-name">${k}</div><div class="mem-val" style="color:${c}">${disp}</div><div class="mem-type" style="color:${c}">${t}</div></div>`;
  }).join('');
}

