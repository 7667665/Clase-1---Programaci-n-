// ════════════════════════════════════════════════
//  PYTHON INTERPRETER (mini)
// ════════════════════════════════════════════════
const env = {};
function evalPython(code){
  const lines=code.split('\n');
  const output=[];
  for(let line of lines){
    line=line.trim();
    if(!line||line.startsWith('#'))continue;
    try{
      // print()
      const pm=line.match(/^print\s*\(([\s\S]*)\)\s*$/);
      if(pm){const res=evalExpr(pm[1].trim(),env);output.push(String(res));continue;}
      // assignment
      const am=line.match(/^([a-zA-Z_][a-zA-Z0-9_]*(?:,\s*[a-zA-Z_][a-zA-Z0-9_]*)*)\s*=\s*([\s\S]+)$/);
      if(am){
        const vars=am[1].split(',').map(s=>s.trim());
        const rhs=am[2].trim();
        if(vars.length>1){
          // tuple unpack: a, b = b, a
          const vals=rhs.split(',').map(s=>evalExpr(s.trim(),env));
          vars.forEach((v,i)=>{env[v]=vals[i];});
        } else {
          env[vars[0]]=evalExpr(rhs,env);
        }
        updateMemDisplay();
        continue;
      }
      // standalone expr
      const r=evalExpr(line,env);
      if(r!==undefined)output.push(String(r));
    }catch(e){output.push('❌ Error: '+e.message);}
  }
  return output;
}

function evalExpr(expr,env){
  expr=expr.trim();
  // fstring
  const fm=expr.match(/^f(['"])([\s\S]*)\1$/);
  if(fm){
    return fm[2].replace(/\{([^}]+)\}/g,(_,v)=>{
      try{return String(evalExpr(v.trim(),env))}catch{return '{'+v+'}'}
    });
  }
  // string
  const sm=expr.match(/^(['"])([\s\S]*)\1$/);
  if(sm)return sm[2];
  // bool
  if(expr==='True')return true;
  if(expr==='False')return false;
  if(expr==='None')return null;
  // functions
  const tm=expr.match(/^type\s*\((.+)\)$/);
  if(tm){const v=evalExpr(tm[1],env);return "<class '"+getType(v)+"'>";}
  const lm=expr.match(/^len\s*\((.+)\)$/);
  if(lm){const v=evalExpr(lm[1],env);if(typeof v==='string')return v.length;throw new Error("object has no len()");}
  const im=expr.match(/^int\s*\((.+)\)$/);
  if(im){return parseInt(evalExpr(im[1],env));}
  const flm=expr.match(/^float\s*\((.+)\)$/);
  if(flm){return parseFloat(evalExpr(flm[1],env));}
  const stm=expr.match(/^str\s*\((.+)\)$/);
  if(stm){return String(evalExpr(stm[1],env));}
  const upm=expr.match(/^(.+)\.upper\s*\(\s*\)$/);
  if(upm){const v=evalExpr(upm[1],env);if(typeof v==='string')return v.toUpperCase();throw new Error("no upper()");}
  const lom=expr.match(/^(.+)\.lower\s*\(\s*\)$/);
  if(lom){const v=evalExpr(lom[1],env);if(typeof v==='string')return v.toLowerCase();throw new Error("no lower()");}
  const spm=expr.match(/^(.+)\.strip\s*\(\s*\)$/);
  if(spm){const v=evalExpr(spm[1],env);if(typeof v==='string')return v.trim();throw new Error("no strip()");}
  // number
  if(/^-?\d+\.\d+$/.test(expr))return parseFloat(expr);
  if(/^-?\d+$/.test(expr))return parseInt(expr);
  // variable
  if(/^[a-zA-Z_][a-zA-Z0-9_]*$/.test(expr)){
    if(expr in env)return env[expr];
    throw new Error("NameError: name '"+expr+"' is not defined");
  }
  // safe math eval with operator precedence
  // handle ** first, then * / // %, then + -
  // simple approach: use Function with controlled scope
  try{
    const varKeys=Object.keys(env);
    const varVals=Object.keys(env).map(k=>env[k]);
    // replace // with a placeholder, ** with Math.pow
    let jsExpr=expr
      .replace(/\*\*/g,'§POW§')
      .replace(/\/\//g,'§IDIV§')
      .replace(/§POW§/g,'**')
      ;
    // Handle integer division
    if(jsExpr.includes('§IDIV§')){
      // parse a // b
      const idem=jsExpr.match(/^(.+?)§IDIV§(.+)$/);
      if(idem){
        const a=evalExpr(idem[1].trim(),env);
        const b=evalExpr(idem[2].trim(),env);
        return Math.floor(a/b);
      }
    }
    // Replace Python ** with JS **
    const fn=new Function(...varKeys,'return ('+jsExpr+')');
    const res=fn(...varVals);
    return res;
  }catch(e){throw new Error("SyntaxError: invalid expression");}
}

function getType(v){
  if(v===true||v===false)return 'bool';
  if(typeof v==='number'){return Number.isInteger(v)?'int':'float';}
  if(typeof v==='string')return 'str';
  if(v===null)return 'NoneType';
  return 'unknown';
}

function updateMemDisplay(){
  const d=document.getElementById('mem-display');
