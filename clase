    <span class="vr">producto1</span><span class="op"> = </span><span class="nm">${p1}</span><br>
    <span class="vr">producto2</span><span class="op"> = </span><span class="nm">${p2}</span><br>
    <span class="vr">producto3</span><span class="op"> = </span><span class="nm">${p3}</span><br>
    <span class="vr">total</span><span class="op"> = </span><span class="vr">producto1</span><span class="op"> + </span><span class="vr">producto2</span><span class="op"> + </span><span class="vr">producto3</span><br>
    <span class="vr">con_iva</span><span class="op"> = </span><span class="vr">total</span><span class="op"> * </span><span class="nm">${(1+iva/100).toFixed(2)}</span><br><br>
    <span class="vr">peso</span><span class="op"> = </span><span class="nm">${peso}</span><span class="cm">  # kg</span><br>
    <span class="vr">estatura</span><span class="op"> = </span><span class="nm">${est}</span><span class="cm">  # m</span><br>
    <span class="vr">imc</span><span class="op"> = </span><span class="vr">peso</span><span class="op"> / </span><span class="vr">estatura</span><span class="op"> ** </span><span class="nm">2</span>
  `;
  document.getElementById('ex2-output').innerHTML=`
    <span style="color:var(--muted)">Subtotal:&nbsp;&nbsp;&nbsp; </span><span style="color:var(--white);font-weight:700">$${total.toFixed(2)}</span><br>
    <span style="color:var(--muted)">IVA ${iva}%:&nbsp;&nbsp;&nbsp;&nbsp; </span><span style="color:var(--orange)">$${(conIva-total).toFixed(2)}</span><br>
    <span style="color:var(--muted)">Total c/IVA: </span><span style="color:var(--yellow);font-weight:700">$${conIva.toFixed(2)}</span><br>
    <span style="color:var(--muted)">─────────────────────</span><br>
    <span style="color:var(--muted)">IMC:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </span><span style="color:var(--cyan);font-weight:700">${imc.toFixed(2)}</span><span style="color:var(--muted)"> → ${imcCat}</span>
  `;
  addScore(20);
}

// ════════════════════════════════════════════════
//  EXERCISE 4 — FIGURES
// ════════════════════════════════════════════════
let curFig='rect';
function selectFigure(f){
  curFig=f;
  ['rect','circ','tria'].forEach(b=>{
    const el=document.getElementById('btn-'+b);
    if(el){el.style.background=b===f?'var(--blue)':'var(--card2)';el.style.color=b===f?'white':'var(--muted)';}
  });
  const inp=document.getElementById('fig-inputs');
  if(!inp)return;
  if(f==='rect'){inp.innerHTML=`<div class="label">Base (m)</div><input id="fi1" type="number" value="5" class="name-input" style="font-size:13px;padding:8px 12px"><div class="label" style="margin-top:6px">Altura (m)</div><input id="fi2" type="number" value="3" class="name-input" style="font-size:13px;padding:8px 12px">`;}
  else if(f==='circ'){inp.innerHTML=`<div class="label">Radio (m)</div><input id="fi1" type="number" value="4" class="name-input" style="font-size:13px;padding:8px 12px">`;}
  else{inp.innerHTML=`<div class="label">Base (m)</div><input id="fi1" type="number" value="6" class="name-input" style="font-size:13px;padding:8px 12px"><div class="label" style="margin-top:6px">Altura (m)</div><input id="fi2" type="number" value="4" class="name-input" style="font-size:13px;padding:8px 12px">`;}
}
function calcFigure(){
  const fi1=parseFloat(document.getElementById('fi1').value)||0;
  const fi2=parseFloat(document.getElementById('fi2')?document.getElementById('fi2').value:0)||0;
  let code='',out='';
  if(curFig==='rect'){
    const area=fi1*fi2,perim=2*(fi1+fi2);
    code=`<span class="vr">base</span><span class="op"> = </span><span class="nm">${fi1}</span><br><span class="vr">altura</span><span class="op"> = </span><span class="nm">${fi2}</span><br><span class="vr">area</span><span class="op"> = </span><span class="vr">base</span><span class="op"> * </span><span class="vr">altura</span><br><span class="vr">perimetro</span><span class="op"> = </span><span class="nm">2</span><span class="op"> * </span>(<span class="vr">base</span><span class="op"> + </span><span class="vr">altura</span>)<br><span class="fn">print</span>(<span class="st">f"Área: {area} m²"</span>)<br><span class="fn">print</span>(<span class="st">f"Perímetro: {perim} m"</span>)`;
    out=`Área:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <span style="color:var(--green);font-weight:700">${area.toFixed(2)} m²</span><br>Perímetro: <span style="color:var(--cyan);font-weight:700">${perim.toFixed(2)} m</span>`;
  } else if(curFig==='circ'){
    const pi=3.14159,area=(pi*fi1*fi1).toFixed(2),perim=(2*pi*fi1).toFixed(2);
    code=`<span class="vr">radio</span><span class="op"> = </span><span class="nm">${fi1}</span><br><span class="vr">pi</span><span class="op"> = </span><span class="nm">3.14159</span><br><span class="vr">area</span><span class="op"> = </span><span class="vr">pi</span><span class="op"> * </span><span class="vr">radio</span><span class="op"> ** </span><span class="nm">2</span><br><span class="vr">circunferencia</span><span class="op"> = </span><span class="nm">2</span><span class="op"> * </span><span class="vr">pi</span><span class="op"> * </span><span class="vr">radio</span><br><span class="fn">print</span>(<span class="st">f"Área: {area} m²"</span>)<br><span class="fn">print</span>(<span class="st">f"Circunferencia: {perim} m"</span>)`;
    out=`Área:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <span style="color:var(--green);font-weight:700">${area} m²</span><br>Circunferencia: <span style="color:var(--cyan);font-weight:700">${perim} m</span>`;
  } else {
    const area=(fi1*fi2/2).toFixed(2),perim=(fi1+fi2+Math.sqrt(fi1*fi1+fi2*fi2)).toFixed(2);
    code=`<span class="vr">base</span><span class="op"> = </span><span class="nm">${fi1}</span><br><span class="vr">altura</span><span class="op"> = </span><span class="nm">${fi2}</span><br><span class="vr">area</span><span class="op"> = </span><span class="nm">0.5</span><span class="op"> * </span><span class="vr">base</span><span class="op"> * </span><span class="vr">altura</span><br><span class="fn">print</span>(<span class="st">f"Área: {area} m²"</span>)`;
    out=`Área: <span style="color:var(--green);font-weight:700">${area} m²</span><br>Hipotenusa ≈ <span style="color:var(--cyan);font-weight:700">${perim} m</span>`;
  }
  document.getElementById('fig-code').innerHTML=code;
  document.getElementById('fig-output').innerHTML=`<span style="font-family:var(--mono);font-size:13px;line-height:2">${out}</span>`;
  addScore(20);
}

// ════════════════════════════════════════════════
//  SWAP VISUALIZER
// ════════════════════════════════════════════════
let swapPhase=0;const swapStates=[
  {a:5,b:10,msg:'Estado inicial',code:'<span class="cm"># a = 5, b = 10</span>'},
  {a:5,b:10,msg:'Guardamos a en temp',code:'<span class="vr">temp</span><span class="op"> = </span><span class="vr">a</span>  <span class="cm"># temp = 5</span>'},
  {a:10,b:10,msg:'a toma el valor de b',code:'<span class="vr">a</span><span class="op"> = </span><span class="vr">b</span>  <span class="cm"># a = 10</span>'},
  {a:10,b:5,msg:'b toma el valor de temp ✅',code:'<span class="vr">b</span><span class="op"> = </span><span class="vr">temp</span>  <span class="cm"># b = 5</span>'},
];
function doSwapStep(){
  swapPhase=(swapPhase+1)%swapStates.length;
  const s=swapStates[swapPhase];
  document.getElementById('svA').textContent=s.a;
  document.getElementById('svB').textContent=s.b;
  document.getElementById('swap-msg').textContent=s.msg;
  document.getElementById('swap-step-code').innerHTML=s.code;
  if(swapPhase===3){
    document.getElementById('swA').style.borderColor='var(--green)';
    document.getElementById('swA').querySelector('.mv').style.color='var(--green)';
    document.getElementById('swB').style.borderColor='var(--green)';
    document.getElementById('swB').querySelector('.mv').style.color='var(--green)';
    addScore(10);
  } else {
    document.getElementById('swA').style.borderColor='var(--cyan)';
    document.getElementById('swA').querySelector('.mv').style.color='var(--cyan)';
    document.getElementById('swB').style.borderColor='var(--cyan)';
    document.getElementById('swB').querySelector('.mv').style.color='var(--cyan)';
  }
}

// ════════════════════════════════════════════════
//  FILL IN THE BLANK
// ════════════════════════════════════════════════
function checkBlank(id,correct,resId,scoreIt){
  const val=document.getElementById(id).value.trim();
  const res=document.getElementById(resId);
  const el=document.getElementById(id);
  if(val.toLowerCase()===correct.toLowerCase()||
     (correct==='3'&&/^\d+$/.test(val))  // any int for semestre
  ){
    el.classList.add('ok');el.classList.remove('no');
    res.textContent='✅ ¡Correcto!';res.style.color='var(--green)';
    if(scoreIt!==false)addScore(5);
  } else {
    el.classList.add('no');el.classList.remove('ok');
    res.textContent='❌ Respuesta: '+correct;res.style.color='var(--red)';
  }
}

// ════════════════════════════════════════════════
//  QUIZ HANDLER
// ════════════════════════════════════════════════
function qa(btn,cardId,result){
  const btns=document.querySelectorAll('#'+cardId+' .qbtn');
  btns.forEach(b=>b.disabled=true);
  if(result==='correct'){
    btn.classList.add('ok');btn.innerHTML='✅ '+btn.textContent;
    addScore(10);
    // show explanation
    const exp=document.getElementById(cardId+'-exp');
    if(exp)exp.style.display='block';
  } else {
    btn.classList.add('no');btn.innerHTML='❌ '+btn.textContent;
    btns.forEach(b=>{if(!b.classList.contains('no'))b.classList.add('ok');});
    const exp=document.getElementById(cardId+'-exp');
    if(exp)exp.style.display='block';
  }
}

// ════════════════════════════════════════════════
//  PLAYGROUND PRESETS
// ════════════════════════════════════════════════
function setPlayground(card,code){
  const inp=document.getElementById('ci20');
  if(inp){inp.value=code;}
  // auto-run multi-line
  const out=document.getElementById('co20');
  const lines=code.split('\n');
  lines.forEach(l=>{
    const echo=document.createElement('div');
    echo.style.color='var(--muted)';echo.style.fontFamily='var(--mono)';echo.style.fontSize='12px';
    echo.textContent='>>> '+l;
    out.appendChild(echo);
  });
  try{
    const results=evalPython(code);
    appendOutput('co20',results.length?results:['']);
  }catch(e){appendOutput('co20',['❌ '+e.message],true);}
  document.getElementById('ci20').value='';
}
